import mariadb
import sys

# Anslutningsuppgifter från docker-compose.yml
DB_CONFIG = {
    "host": "localhost",
    "port": 3306,
    "user": "user",
    "password": "123",
    "database": "petshop"
}

def connect_to_db():
    try:
        conn = mariadb.connect(**DB_CONFIG)
        return conn
    except mariadb.Error as e:
        print(f"Error connecting to MariaDB: {e}")
        sys.exit(1)

def get_orders_for_warehouse(warehouse_id):
    conn = connect_to_db()
    cursor = conn.cursor(dictionary=True)
    query = """
        SELECT o.order_id, o.customer_id, oi.product_id, oi.quantity
        FROM orders o
        JOIN order_items oi ON o.order_id = oi.order_id
        WHERE o.warehouse_id = %s AND o.status = 'pending';
    """
    cursor.execute(query, (warehouse_id,))
    orders = cursor.fetchall()
    conn.close()
    return orders

def get_inventory(warehouse_id):
    conn = connect_to_db()
    cursor = conn.cursor(dictionary=True)
    query = "SELECT product_id, quantity FROM inventory WHERE warehouse_id = %s;"
    cursor.execute(query, (warehouse_id,))
    inventory = {row["product_id"]: row["quantity"] for row in cursor.fetchall()}
    conn.close()
    return inventory

def fulfill_orders(warehouse_id):
    orders = get_orders_for_warehouse(warehouse_id)
    inventory = get_inventory(warehouse_id)
    
    conn = connect_to_db()
    cursor = conn.cursor()
    
    missing_products = {}

    for order in orders:
        order_id = order["order_id"]
        product_id = order["product_id"]
        required_quantity = order["quantity"]

        available_quantity = inventory.get(product_id, 0)

        if available_quantity < required_quantity:
            missing_products[product_id] = required_quantity - available_quantity
        else:
            # Minska lagersaldo och uppdatera orderstatus
            cursor.execute(
                "UPDATE inventory SET quantity = quantity - %s WHERE warehouse_id = %s AND product_id = %s;",
                (required_quantity, warehouse_id, product_id)
            )
            cursor.execute("UPDATE orders SET status = 'fulfilled' WHERE order_id = %s;", (order_id,))
    
    conn.commit()
    conn.close()

    # Skriva ut saknade produkter om lagret inte räcker
    if missing_products:
        print("Ordern kan inte uppfyllas. Följande produkter saknas:")
        for product_id, needed in missing_products.items():
            print(f"- Produkt-ID: {product_id}, Saknas: {needed} enheter")
    else:
        print("Alla ordrar kunde uppfyllas.")

if __name__ == "__main__":
    warehouse_id = 2  # Ange ID för Small Warehouse
    fulfill_orders(warehouse_id)



