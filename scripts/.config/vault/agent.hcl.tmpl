auto_auth {
  method "token_file" {
    config = {
      token_file_path = "@@RUNTIME_DIR@@/vault/token"
    }
  }

  sink "file" {
    config = {
      path = "@@RUNTIME_DIR@@/vault/token"
      mode = 0600
    }
  }
}

vault {
  address = "@@VAULT_ADDR@@"
}

listener "unix" {
  address     = "@@RUNTIME_DIR@@/vault/agent.sock"
  tls_disable = true
}

cache {
  use_auto_auth_token = true
}
