~/bin/hashwall -b '#111' -f '#222' -s 12 

# Återställ tema till standard
hc attr theme.tiling.reset 1
hc attr theme.floating.reset 1

# Definiera färger för ramen
hc set frame_border_active_color '#767676'  # Färg när fönstret är aktivt
hc set frame_border_normal_color '#222222'  # Standardfärg när fönstret är inaktivt

# Definiera bakgrundsfärger
hc set frame_bg_normal_color '[0]#222222'  # Bakgrundsfärg för standard
hc set frame_bg_active_color '[0]#767676'  # Bakgrundsfärg när fönstret är aktivt

# Övriga inställningar
hc set frame_border_width 2
hc set always_show_frame 1
hc set frame_bg_transparent 0
hc set frame_active_opacity 1
hc set frame_normal_opacity 1
hc set frame_transparent_width 0
hc set frame_gap 5

# Tema-färger och inställningar
hc attr theme.active.color '#767676'
hc attr theme.normal.color '#222222'
hc attr theme.urgent.color '#0087af'
hc attr theme.inner_width 4
hc attr theme.inner_color '#767676'
hc attr theme.border_width 2
hc attr theme.floating.border_width 2
hc attr theme.floating.outer_width 2
hc attr theme.floating.outer_color '#af5f5f'
hc attr theme.active.inner_color '#767676'
hc attr theme.active.outer_color '#767676'
hc attr theme.background_color '[0]#222222'

# Justera fönstergap och padding
hc set window_gap 20
hc set frame_padding 0
hc set smart_window_surroundings 0
hc set smart_frame_surroundings 1
hc set mouse_recenter_gap 0
hc set focus_follows_mouse 1
hc set focus_stealing_prevention 1
