~/bin/hashwall -b '#111' -f '#222' -s 12 


# Återställ tema till standard
hc attr theme.tiling.reset 1
hc attr theme.floating.reset 1

# Definiera färger för ram och bakgrund
hc set frame_border_active_color '#767676'
hc set frame_border_normal_color '#222222'
hc set frame_bg_normal_color '#232323'
hc set frame_bg_active_color '#4e4e4e'

# Justera ramar och bakgrunder
hc set frame_border_width 2
hc set always_show_frame off
hc set frame_bg_transparent off
hc set frame_transparent_width 0
hc set frame_gap 10

hc attr theme.title_height 20
hc attr theme.padding_left 5

# Definiera färger för tema
hc attr theme.active.color '#9c353e'
hc attr theme.normal.color '#594646'
hc attr theme.urgent.color '#7811A1dd'
hc attr theme.normal.title_color '#898989'

hc attr theme.inner_width 2
hc attr theme.inner_color '#4e4e4e'
hc attr theme.border_width 1
hc attr theme.floating.border_width 1
hc attr theme.floating.outer_width 1
hc attr theme.floating.outer_color '#4e4e4e'
hc attr theme.active.inner_color '#767676'
hc attr theme.urgent.inner_color '#9A65B0'
hc attr theme.normal.inner_color '#606060'

# Kopiera inner_color till outer_color
for state in active urgent normal ; do
    hc substitute C theme.${state}.inner_color \
        attr theme.${state}.outer_color C
done

hc attr theme.active.outer_width 2
hc attr theme.background_color '#141414'

# Justera fönstergap och padding
hc set window_gap 10
hc set frame_padding 5
hc set smart_window_surroundings 1
hc set smart_frame_surroundings 1
hc set mouse_recenter_gap 0
