/* Skapar en färgglad animerad kantlinje runt aktiv flik */
@keyframes slide {
    0% {
        background-position: 0% 50%;
    }
    50% {
        background-position: 100% 50%;
    }
    100% {
        background-position: 0% 50%;
    }
}

.tabbrowser-tab[selected] > .tab-stack::after {
    content: "";
    display: block;
    position: absolute;
    bottom: 0px; /* Ändrad från 0 till 0px för tydligare specifikation */
    left: 0;
    right: 0;
    height: 4px; /* Kontrollera att höjden är exakt */
    margin: 0; /* Ingen extra marginal */
    padding: 0; /* Ingen extra padding */
    background-image: linear-gradient(
        90deg,
        #707746, /* Mörkgrön */
        #909A49, /* Olivgrön */
        #A09F73, /* Beige */
        #837E5E, /* Varmgrå */
        #65694A  /* Mörk Mossgrön */
    );
    background-size: 200% 100%; /* Endast horisontell rörelse */
    animation: slide 8s infinite ease-in-out; /* Jämn fram och tillbaka rörelse */
    z-index: 2;
    pointer-events: none; /* Förhindra att elementet påverkar musinteraktion */
}

.tab-background[selected] {
    border: none !important;
    outline: none !important;
    background-clip: padding-box !important;
    position: relative;
}
