~/.dotfiles/zsh/.zshrc:

#!/usr/bin/env zsh
# Main config - only loads other files

# Set XDG before anything else
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"

# Load all zsh config files
for config in "$XDG_CONFIG_HOME"/zsh/[^_]*.zsh; do
  source "$config"
done


~/.dotfiles/zsh/.config/zsh/env.zsh:
zsh
Copy

# Environment variables
export EDITOR='nvim'
export VISUAL='nvim'
export PATH="$HOME/.local/bin:$PATH"

# Language settings
export LANG='en_US.UTF-8'
export LC_ALL='en_US.UTF-8'

~/.dotfiles/zsh/.config/zsh/history.zsh:
# History settings
export HISTFILE="$XDG_DATA_HOME/zsh/history"
HISTSIZE=100000
SAVEHIST=100000

setopt HIST_IGNORE_SPACE
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_SAVE_NO_DUPS
setopt HIST_FIND_NO_DUPS
setopt SHARE_HISTORY
setopt APPEND_HISTORY
setopt EXTENDED_HISTORY

~/.dotfiles/zsh/.config/zsh/completion.zsh:
# Completion system
autoload -Uz compinit
compinit -u -d "$XDG_CACHE_HOME/zsh/zcompdump"

zstyle ':completion:*' menu no
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'

# FZF integration
if (( $+commands[fzf] )); then
  zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color $realpath'
  zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'ls --color $realpath'
fi

~/.dotfiles/zsh/.config/zsh/plugins.zsh:
# Zinit setup
ZINIT_HOME="${XDG_DATA_HOME}/zinit/zinit.git"
if [[ ! -f "${ZINIT_HOME}/zinit.zsh" ]]; then
    mkdir -p "${ZINIT_HOME}"
    git clone https://github.com/zdharma-continuum/zinit.git "${ZINIT_HOME}"
fi
source "${ZINIT_HOME}/zinit.zsh"

# Plugins
zinit snippet OMZP::sudo
zinit light zsh-users/zsh-syntax-highlighting
zinit light zsh-users/zsh-autosuggestions

# Tools
(( $+commands[zoxide] )) && eval "$(zoxide init --cmd cd zsh)"
(( $+commands[fzf] )) && source <(fzf --zsh)

zinit cdreplay -q

~/.dotfiles/zsh/.config/zsh/keys.zsh:
# Key bindings
bindkey -v  # Vi mode

bindkey '^f' autosuggest-accept
bindkey '^h' backward-char
bindkey '^j' history-search-backward
bindkey '^k' history-search-forward
bindkey '^l' forward-char
bindkey '^z' kill-region
bindkey '^R' history-incremental-search-backward


~/.dotfiles/zsh/.config/zsh/prompt.zsh:
# Prompt setup
autoload -Uz colors vcs_info && colors
setopt PROMPT_SUBST

# Git symbols
ICO_DIRTY="⚡"
ICO_AHEAD="▲"
ICO_BEHIND="▼"
ICO_DIVERGED="⥮"

# Optimized git prompt
git_prompt_info() {
    local ref dirty stat
    ref=$(git symbolic-ref --short HEAD 2>/dev/null || 
          git describe --tags --exact-match HEAD 2>/dev/null) || return

    git diff --quiet --ignore-submodules 2>/dev/null || dirty=$ICO_DIRTY

    case $(git rev-list --count --left-right @{upstream}...HEAD 2>/dev/null) in
        "") ;;
        "0"*) ;;
        *"0") stat=$ICO_AHEAD ;;
        *) stat=$ICO_DIVERGED ;;
    esac

    echo "%F{241}[%F{244}${ref}${dirty}${stat}%F{241}]"
}

# Main prompt
if [[ -v VIMRUNTIME ]]; then
    PROMPT='%F{9}─────%f '
elif [[ -v SSH_TTY ]]; then
    PROMPT='%F{13}%m%f '
else
    PROMPT='%F{11}─────%f '
fi

RPROMPT='%F{8}%~ $(git_prompt_info)%f'
