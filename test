stages:
  - build
  - test
  - deploy
  - teardown

variables:
  DOCKER_TAG: $([ "$CI_COMMIT_BRANCH" = "$CI_DEFAULT_BRANCH" ] && echo "latest" || echo "$CI_COMMIT_REF_NAME")
  STACK_NAME: "$CI_PROJECT_PATH_SLUG-$CI_COMMIT_REF_SLUG"

.build-settings: &build-settings
  image: docker:20
  before_script:
    - docker login $CI_REGISTRY -u $CI_REGISTRY_USER -p $CI_REGISTRY_PASSWORD
  rules:
    - if: $CI_COMMIT_REF_NAME == $CI_DEFAULT_BRANCH || $CI_MERGE_REQUEST_ID
      changes:
        - Dockerfile
        - "*.py"
        - requirements*.txt

build-api:
  <<: *build-settings
  stage: build
  script:
    - ./scripts/build.sh api

build-utils:
  <<: *build-settings
  stage: build
  script:
    - ./scripts/build.sh utils
  rules:
    - if: $CI_COMMIT_REF_NAME == $CI_DEFAULT_BRANCH
      changes:
        - Dockerfile-utils

unit-tests:
  image: $CI_REGISTRY_IMAGE:test-$CI_COMMIT_REF_NAME
  stage: test
  script:
    - ./scripts/test.sh
  coverage: '/TOTAL.*? (100(?:\.0+)?\%|[1-9]?\d(?:\.\d+)?\%)$/'
  rules:
    - if: $CI_MERGE_REQUEST_ID
      changes:
        - Dockerfile
        - "*.py"
        - requirements*.txt

deploy:
  image: $CI_REGISTRY_IMAGE/utils:latest
  stage: deploy
  environment:
    name: review/$CI_COMMIT_REF_NAME
    url: https://$STACK_NAME.cc25.chasacademy.dev/docs
    on_stop: stop_review
  script:
    - ./scripts/deploy.sh
  rules:
    - if: $CI_MERGE_REQUEST_ID || $CI_COMMIT_REF_NAME == $CI_DEFAULT_BRANCH

stop_review:
  image: $CI_REGISTRY_IMAGE/utils:latest
  stage: teardown
  environment:
    name: review/$CI_COMMIT_REF_NAME
    action: stop
  script:
    - ./scripts/stop_review.sh
  rules:
    - if: $CI_MERGE_REQUEST_ID
      when: manual

