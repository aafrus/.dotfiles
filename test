~/bin/hashwall -b '#111' -f '#222' -s 12 

# Återställ tema till standard
hc attr theme.tiling.reset 1
hc attr theme.floating.reset 1

# Definiera färger för ram och bakgrund
hc set frame_border_active_color '#767676'  # Färg när vald
hc set frame_border_normal_color '#222222'  # Standardfärg

# Bakgrundsfärger
hc set frame_bg_normal_color '#232323'  # Bakgrundsfärg för standard
hc set frame_bg_active_color '#4e4e4e'  # Bakgrundsfärg när vald

# Övriga inställningar
hc set frame_border_width 2
hc set always_show_frame off
hc set frame_bg_transparent off
hc set frame_transparent_width 0
hc set frame_gap 10

# Dölj titelraden
hc attr theme.title_height 0
