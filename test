# theme
hc attr theme.tiling.reset 1
hc attr theme.floating.reset 1
hc set frame_border_active_color '#807b64'
hc set frame_border_normal_color '#131313'
hc set frame_bg_normal_color '#202020'
hc set frame_bg_active_color '#131313'
hc set frame_border_width 0
hc set always_show_frame 0
hc set frame_bg_transparent 1
hc set frame_transparent_width 0
hc set frame_gap 2

# Aktiva fönster har en grön ram
hc attr theme.active.inner_color '#78824b'  # Grön färg för den inre ramen på aktiva fönster
hc attr theme.active.outer_color '#78824b'  # Grön färg för den yttre ramen på aktiva fönster
hc attr theme.inner_width 2  # Bredd på den inre ramen för aktiva fönster
hc attr theme.outer_width 2  # Bredd på den yttre ramen för aktiva fönster

# Inaktiva fönster har ingen synlig ram
hc attr theme.normal.inner_color '#00000000'  # Transparent inre ram för inaktiva fönster
hc attr theme.normal.outer_color '#00000000'  # Transparent yttre ram för inaktiva fönster
hc attr theme.inner_width 0  # Ingen inre ram för inaktiva fönster
hc attr theme.outer_width 0  # Ingen yttre ram för inaktiva fönster

# Flytande fönster
hc attr theme.floating.inner_color '#78824b'  # Grön färg för den inre ramen på flytande fönster
hc attr theme.floating.outer_color '#78824b'  # Grön färg för den yttre ramen på flytande fönster
hc attr theme.floating.inner_width 2  # Bredd på den inre ramen för flytande fönster
hc attr theme.floating.outer_width 2  # Bredd på den yttre ramen för flytande fönster

# Bakgrundsfärg
hc attr theme.background_color '#1e1b1c'

hc set window_gap 10
hc set frame_padding 0
hc set smart_window_surroundings 0
hc set smart_frame_surroundings 1
hc set mouse_recenter_gap 0
