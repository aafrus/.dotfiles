# /etc/nixos/configuration.nix
{ config, pkgs, ... }:

{
  # Importera hårdvarukonfigurationen från nätverksskanningen.
  imports = [
    ./hardware-configuration.nix
  ];

  # Använd systemd-boot som bootloader.
  boot.loader.systemd-boot.enable = true;
  boot.loader.efi.canTouchEfiVariables = true;

  # Nätverksinställningar.
  networking.hostName = "T-1000";
  networking.wireless.enable = true;
  networking.networkmanager.enable = true;

  # Tidszon.
  time.timezone = "Europe/Stockholm";

  # Stöd för internationalisering och tangentbordslayout.
  i18n.defaultLocale = "en_US.UTF-8";
  services.xserver.layout = "se";

  # Aktivera X-servern.
  services.xserver.enable = true;

  # Inaktivera display managers (som LightDM, GDM, etc.)
  services.xserver.displayManager.lightdm.enable = false;

  # Konfigurera gettyservice för automatisk inloggning på tty1.
  services.getty.autologinUser = "ns";

  # Användarkonfiguration. Byt ut dittanvändarnamn.
  users.users.ns = {
    isNormalUser = true;
    extraGroups = [ "wheel" "networkmanager" "video" ];
  };

  # Systempaket, inkl. CWM, xinit och urxvt.
  environment.systemPackages = with pkgs; [
    cwm # Din önskade window manager
    xorg.xinit # Krävs för att köra startx
    rxvt-unicode # uRxvt, din terminalemulator
  ];

  # Skapa en fil i användarens hemkatalog som startar X-servern automatiskt.
  environment.etc."skel/.zprofile".source = pkgs.writeText "zprofile" ''
    if [ -z "$DISPLAY" ] && [ "$(tty)" = "/dev/tty1" ]; then
      exec startx
    fi
  '';

  # Skapa .xinitrc som säger åt startx att starta CWM.
  environment.etc."skel/.xinitrc".source = pkgs.writeText "xinitrc" ''
    #!/bin/sh
    exec cwm
  '';

  # Andra tjänster.
  services.printing.enable = true;
  services.pipewire.enable = true;

  # ... lägg till resten av din konfiguration här om det behövs.
}
