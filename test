# /etc/nixos/configuration.nix
{ config, pkgs, ... }:

{
  # Import hardware configuration from the network scan.
  imports = [
    ./hardware-configuration.nix
  ];

  # Use systemd-boot as the bootloader.
  boot.loader.systemd-boot.enable = true;
  boot.loader.efi.canTouchEfiVariables = true;

  # Network settings.
  networking.hostName = "T-1000";
  # Use NetworkManager only, do not enable the legacy wireless configuration.
  networking.wireless.enable = false; # Corrected: This line was causing the error
  networking.networkmanager.enable = true;

  # Timezone and NTP synchronization.
  # This section needs to be configured correctly.
  time.timeZone = "Europe/Stockholm";
  services.timesyncd.enable = true;

  # Internationalization and keyboard layout support.
  i18n.defaultLocale = "en_US.UTF-8";
  services.xserver.layout = "se";

  # Enable the X server.
  services.xserver.enable = true;

  # Disable display managers (such as LightDM, GDM, etc.)
  services.xserver.displayManager.lightdm.enable = false;

  # Configure the getty service for automatic login on tty1.
  services.getty.autologinUser = "ns";

  # User configuration.
  users.users.ns = {
    isNormalUser = true;
    extraGroups = [ "wheel" "networkmanager" "video" ];
    # Set zsh as the default shell for this user.
    shell = pkgs.zsh;
  };

  # System packages, including CWM, xinit, urxvt, and common shells.
  environment.systemPackages = with pkgs; [
    cwm # Your desired window manager
    xorg.xinit # Required to run startx
    rxvt-unicode # uRxvt, your terminal emulator
    zsh # Corrected: This was missing and caused the zsh error
    bash
    gedit # Added for easier editing
  ];

  # Corrected: Enable zsh programs explicitly to resolve the shell error.
  programs.zsh.enable = true;

  # Create a file in the user's home directory that automatically starts the X server.
  # This file uses .zprofile, which is sourced by zsh login shells, making it more reliable.
  environment.etc."skel/.zprofile".source = pkgs.writeText "zprofile" ''
    if [ -z "$DISPLAY" ] && [ "$(tty)" = "/dev/tty1" ]; then
      exec startx
    fi
  '';

  # Create .xinitrc which tells startx to start CWM.
  environment.etc."skel/.xinitrc".source = pkgs.writeText "xinitrc" ''
    #!/bin/sh
    exec cwm
  '';

  # Other services.
  services.printing.enable = true;
  services.pipewire.enable = true;

  # Add the 'system.stateVersion' to resolve the warning.
  system.stateVersion = "23.11"; # Corrected: Set the state version to a recent value

  # ... add the rest of your configuration here if needed.
}
