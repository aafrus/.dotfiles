stages: [build, test, deploy, teardown]

variables:
  DOCKER_TAG: $([ "$CI_COMMIT_BRANCH" = "$CI_DEFAULT_BRANCH" ] && echo "latest" || echo "$CI_COMMIT_REF_NAME")
  STACK_NAME: "$CI_PROJECT_PATH_SLUG-$CI_COMMIT_REF_SLUG"
  PORTAINER_URL: "https://portainer.cc25.chasacademy.dev"

# 🔄 Reusable blocks
.use_scripts: &use_scripts
  before_script:
    - chmod +x ./scripts/*
    - [ -f ".ci_cache" ] && source .ci_cache

.docker_rules: &docker_rules
  rules:
    - if: $CI_MERGE_REQUEST_ID
      changes: [Dockerfile, "*.py", requirements.txt, requirements-dev.txt]
    - if: $CI_COMMIT_REF_NAME == $CI_DEFAULT_BRANCH
      changes: [Dockerfile, "*.py", requirements.txt, requirements-dev.txt]

# 🏗️ Build
build-api:
  image: docker:20
  stage: build
  <<: *use_scripts
  script: ./scripts/build base $DOCKER_TAG
  rules:
    - <<: *docker_rules

build-test:
  image: docker:20
  stage: build
  <<: *use_scripts
  script: ./scripts/build test test-$DOCKER_TAG
  needs: [build-api]
  rules:
    - <<: *docker_rules

build-utils:
  image: docker:20
  stage: build
  <<: *use_scripts
  script: ./scripts/build utils latest -f Dockerfile-utils
  rules:
    - if: $CI_COMMIT_REF_NAME == $CI_DEFAULT_BRANCH
      changes: [Dockerfile-utils]

# 🧪 Testing
unit-tests:
  image: $CI_REGISTRY_IMAGE:test-$CI_COMMIT_REF_NAME
  stage: test
  <<: *use_scripts
  script: ./scripts/test
  coverage: '/TOTAL.*? (100(?:\.0+)?\%|[1-9]?\d(?:\.\d+)?\%)$/'
  artifacts:
    reports:
      cobertura: coverage.xml
  needs: [build-test]
  rules:
    - <<: *docker_rules

# 🚀 Deployment
deploy:
  image: $CI_REGISTRY_IMAGE/utils:latest
  stage: deploy
  <<: *use_scripts
  script: ./scripts/deploy
  environment:
    name: review/$CI_COMMIT_REF_NAME
    url: https://$STACK_NAME.cc25.chasacademy.dev/docs
    on_stop: stop_review
  cache:
    key: $CI_COMMIT_REF_SLUG
    paths: [.ci_cache]
  needs: [build-utils, unit-tests]
  rules:
    - if: $CI_MERGE_REQUEST_ID
    - if: $CI_COMMIT_REF_NAME == $CI_DEFAULT_BRANCH

# 🛑 Environment Stop
stop_review:
  image: $CI_REGISTRY_IMAGE/utils:latest
  stage: teardown
  <<: *use_scripts
  script: ./scripts/stop
  environment:
    name: review/$CI_COMMIT_REF_NAME
    action: stop
  when: manual
  rules:
    - if: $CI_MERGE_REQUEST_ID



2. /scripts

build:

#!/bin/bash
set -eo pipefail

target=$1
tag=$2
shift 2

docker login -u "$CI_REGISTRY_USER" -p "$CI_REGISTRY_PASSWORD" "$CI_REGISTRY"

docker buildx build \
  --cache-from="$CI_REGISTRY_IMAGE:latest" \
  -t "$CI_REGISTRY_IMAGE:$tag" \
  --push \
  --target="$target" \
  "$@" .

test:

#!/bin/bash
pytest --cov --cov-report=xml --cov-fail-under=90

deploy:

#!/bin/bash
set -eo pipefail

source ./scripts/auth
envsubst <docker-compose.yml >deployable-compose.yml
source ./scripts/stack


auth:

#!/bin/bash
export PORTAINER_TOKEN=$(curl -sS "$PORTAINER_URL/api/auth" \
  --json "{\"username\":\"$PORTAINER_USER\",\"password\":\"$PORTAINER_PASSWORD\"}" \
  | jq -r '.jwt')

export ENDPOINT_ID=$(curl -sS "$PORTAINER_URL/api/endpoints" \
  -H "Authorization: Bearer $PORTAINER_TOKEN" \
  | jq -r '.[] | select(.Name=="primary").Id')

stack:

#!/bin/bash
stack_id=$(curl -sS "$PORTAINER_URL/api/stacks" \
  -H "Authorization: Bearer $PORTAINER_TOKEN" \
  | jq -r --arg name "$STACK_NAME" '.[] | select(.Name==$name) | .Id')

[ -z "$stack_id" ] && ./scripts/create_stack || ./scripts/update_stack


stop:

#!/bin/bash
set -eo pipefail

echo "=== SAFETY CHECK ==="
echo "Only removing $STACK_NAME if it exists"

source ./scripts/auth

# Get stack ID (fail-safe)
stack_id=$(curl -sS "$PORTAINER_URL/api/stacks" \
  -H "Authorization: Bearer $PORTAINER_TOKEN" \
  | jq -r --arg name "$STACK_NAME" '.[] | select(.Name==$name) | .Id') || true

[ -z "$stack_id" ] && { echo "Stack already gone - nothing to do"; exit 0; }

# Confirmation prompt
echo "=== CONFIRM DELETION ==="
echo "Stack: $STACK_NAME (ID: $stack_id)"
echo "Press ENTER to continue, CTRL+C to abort"
read -r

# Execute deletion
curl -sS -X DELETE "$PORTAINER_URL/api/stacks/$stack_id?endpointId=$ENDPOINT_ID" \
  -H "Authorization: Bearer $PORTAINER_TOKEN"
echo "Stack removed successfully"
