#!/bin/bash
set -e

export PORTAINER_TOKEN=$(curl -s -X POST "https://portainer.cc25.chasacademy.dev/api/auth" --json '{"username": "'$PORTAINER_USER'", "password": "'$PORTAINER_PASSWORD'"}' | jq -r '.jwt')
export ENDPOINT_ID=$(curl -s https://portainer.cc25.chasacademy.dev/api/endpoints -H "Authorization: Bearer $PORTAINER_TOKEN" | jq '.[] | select(.Name == "primary") | .Id')
export SWARM_ID=$(curl -s https://portainer.cc25.chasacademy.dev/api/endpoints -H "Authorization: Bearer $PORTAINER_TOKEN" | jq '.[] | select(.Name == "primary") | .Snapshots[0].DockerSnapshotRaw.Info.Swarm.Cluster.ID' -r)

envsubst <docker-compose.yml>deployable-compose.yml
STACK_ID=$(curl -s https://portainer.cc25.chasacademy.dev/api/stacks -H "Authorization: Bearer $PORTAINER_TOKEN" | jq '.[] | select(.Name == "'$STACK_NAME'") | .Id')

if [ -z "$STACK_ID" ]; then
  echo "Creating new stack..."
  curl -X POST "https://portainer.cc25.chasacademy.dev/api/stacks/create/swarm/file?endpointId=$ENDPOINT_ID" \
    -H "Authorization: Bearer $PORTAINER_TOKEN" \
    -F Name="$STACK_NAME" \
    -F SwarmID="$SWARM_ID" \
    -F file=@deployable-compose.yml | jq
else
  echo "Updating existing stack..."
  curl -X PUT "https://portainer.cc25.chasacademy.dev/api/stacks/$STACK_ID?endpointId=$ENDPOINT_ID" \
    -H "Authorization: Bearer $PORTAINER_TOKEN" \
    --json "{\"prune\": true, \"pullImage\": true, \"stackFileContent\": \"$(cat deployable-compose.yml)\"}" | jq
fi

