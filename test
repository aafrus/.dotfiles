/* Skapar en färgglad animerad kantlinje runt aktiv flik */
@keyframes slide {
    0% {
        background-position: 0% 50%;
    }
    50% {
        background-position: 100% 50%;
    }
    100% {
        background-position: 0% 50%;
    }
}

.tab-background[selected]::after {
    content: "";
    display: block;
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4px;
    background-image: linear-gradient(
        90deg,
        #707746, /* Mörkgrön */
        #909A49, /* Olivgrön */
        #A09F73, /* Beige */
        #837E5E, /* Varmgrå */
        #65694A  /* Mörk Mossgrön */
    );
    background-size: 200%; /* Gör gradienten större för att skapa rörelse */
    animation: slide 8s infinite ease-in-out; /* Jämn fram och tillbaka rörelse */
    z-index: 2;
}

/* Tar bort standardramen för aktiva flikar */
.tab-background[selected] {
    border: none !important;
    outline: none !important;
    position: relative;
}

.tab-stack {
    position: relative;
}
