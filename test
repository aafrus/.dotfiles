~/.zshrc (ultimat minimal version)

#!/usr/bin/env zsh
# Minimal main config - only loads other files

# XDG base directories (must be set first)
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"

# Load all zsh config files (except those starting with _)
for config in "$XDG_CONFIG_HOME"/zsh/[^_]*.zsh; do
  source "$config"
done

~/.config/zsh/history.zsh

# History settings
export HISTFILE="$XDG_DATA_HOME/zsh/history"
HISTSIZE=100000
SAVEHIST=100000

setopt HIST_IGNORE_SPACE      # Ignore commands starting with space
setopt HIST_IGNORE_ALL_DUPS   # Remove older duplicate entries
setopt HIST_SAVE_NO_DUPS      # Don't save duplicates in history file
setopt HIST_FIND_NO_DUPS      # Don't show duplicates when searching
setopt SHARE_HISTORY          # Share history between sessions
setopt APPEND_HISTORY         # Append rather than overwrite
setopt EXTENDED_HISTORY       # Save timestamp and duration

~/.config/zsh/completion.zsh
zsh
Copy

# Completion system
autoload -Uz compinit
compinit -u -d "$XDG_CACHE_HOME/zsh/zcompdump"

# Completion styling
zstyle ':completion:*' menu no
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'

# FZF-tab integration
if (( $+commands[fzf] )); then
  zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color $realpath'
  zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'ls --color $realpath'
fi

~/.config/zsh/plugins.zsh

# Initialize plugins
plugin_dir="$XDG_DATA_HOME/zsh/plugins"

# Load Oh My Zsh sudo plugin
zinit snippet OMZP::sudo

# Load syntax highlighting
source "$plugin_dir/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" 2>/dev/null || {
  mkdir -p "$plugin_dir"
  git clone --depth 1 https://github.com/zsh-users/zsh-syntax-highlighting.git "$plugin_dir/zsh-syntax-highlighting"
  source "$plugin_dir/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
}

# Load autosuggestions
source "$plugin_dir/zsh-autosuggestions/zsh-autosuggestions.zsh" 2>/dev/null || {
  git clone --depth 1 https://github.com/zsh-users/zsh-autosuggestions.git "$plugin_dir/zsh-autosuggestions"
  source "$plugin_dir/zsh-autosuggestions/zsh-autosuggestions.zsh"
}
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=8'

# Initialize zoxide and fzf
(( $+commands[zoxide] )) && eval "$(zoxide init --cmd cd zsh)"
(( $+commands[fzf] )) && source <(fzf --zsh)

# Finalize zinit
zinit cdreplay -q


~/.config/zsh/keys.zsh

# Key bindings
bindkey '^f' autosuggest-accept         # Ctrl+f to accept suggestion
bindkey '^h' backward-char             # Ctrl+h move left
bindkey '^j' history-search-backward   # Ctrl+j search history back
bindkey '^k' history-search-forward    # Ctrl+k search history forward
bindkey '^l' forward-char              # Ctrl+l move right
bindkey '^z' kill-region               # Ctrl+z delete line

~/.config/zsh/prompt.zsh 

# Enable colors and prompt substitution
autoload -Uz colors && colors
setopt PROMPT_SUBST

# Git symbols
ICO_DIRTY="⚡"
ICO_AHEAD="▲"
ICO_BEHIND="▼"
ICO_DIVERGED="⥮"

# Optimized git prompt
git_prompt_info() {
  # Fast git check
  local git_dir
  git_dir=$(git rev-parse --git-dir 2>/dev/null) || return
  
  # Get current reference
  local ref
  ref=$(git symbolic-ref --short HEAD 2>/dev/null || 
        git describe --tags --exact-match HEAD 2>/dev/null ||
        git rev-parse --short HEAD 2>/dev/null)

  # Fast dirty check (5x faster than --shortstat)
  local dirty
  git diff --quiet --ignore-submodules 2>/dev/null || dirty=$ICO_DIRTY

  # Fast remote status check
  local stat
  case "$(git rev-list --count --left-right @{upstream}...HEAD 2>/dev/null)" in
    "") ;;  # No upstream
    "0"*) ;;  # Equal
    *"0") stat=$ICO_AHEAD ;;
    *) stat=$ICO_DIVERGED ;;
  esac

  # Your exact format
  echo "%F{241}[%F{244}${ref}${dirty}${stat}%F{241}]"
}

# Main prompt (your exact style)
if [[ -v VIMRUNTIME ]]; then
  PROMPT='%F{9} ──── ─%f '       # Red for Vim
elif [[ -v SSH_TTY ]]; then
  PROMPT='%F{13}%m%F{3}_%f '     # Purple for SSH
else
  PROMPT='%F{11} ──── ─%f '      # Yellow normal
fi

RPROMPT='%F{15}%~ $(git_prompt_info)%f'

bindkey '^f' autosuggest-accept         # Ctrl+f to accept suggestion
bindkey '^h' backward-char             # Ctrl+h move left
bindkey '^j' history-search-backward   # Ctrl+j search history back
bindkey '^k' history-search-forward    # Ctrl+k search history forward
bindkey '^l' forward-char              # Ctrl+l move right
bindkey '^z' kill-region               # Ctrl+z delete line
