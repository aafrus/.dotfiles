stages: [build, test, deploy, teardown]

variables:
  DOCKER_TAG: $([ "$CI_COMMIT_BRANCH" = "$CI_DEFAULT_BRANCH" ] && echo "latest" || echo "$CI_COMMIT_REF_NAME")
  STACK_NAME: "$CI_PROJECT_PATH_SLUG-$CI_COMMIT_REF_SLUG"
  PORTAINER_URL: "https://portainer.cc25.chasacademy.dev"

.use_scripts: &use_scripts
  before_script:
    - chmod +x ./scripts/*
    - [ -f ".ci_cache" ] && source .ci_cache

.docker_rules: &docker_rules
  rules:
    - if: $CI_MERGE_REQUEST_ID
      changes: [Dockerfile, "*.py", requirements*]
    - if: $CI_COMMIT_REF_NAME == $CI_DEFAULT_BRANCH
      changes: [Dockerfile, "*.py", requirements*]

build-api:
  image: docker:20
  stage: build
  <<: [*use_scripts, *docker_rules]
  script: ./scripts/build base $DOCKER_TAG

build-test:
  image: docker:20
  stage: build
  <<: [*use_scripts, *docker_rules]
  script: ./scripts/build test test-$DOCKER_TAG
  needs: [build-api]

build-utils:
  image: docker:20
  stage: build
  <<: *use_scripts
  script: ./scripts/build utils latest -f Dockerfile-utils
  rules:
    - if: $CI_COMMIT_REF_NAME == $CI_DEFAULT_BRANCH
      changes: [Dockerfile-utils]

unit-tests:
  image: $CI_REGISTRY_IMAGE:test-$CI_COMMIT_REF_NAME
  stage: test
  <<: *use_scripts
  script: ./scripts/test
  coverage: '/TOTAL.*? (100(?:\.0+)?\%|[1-9]?\d(?:\.\d+)?\%)$/'
  artifacts:
    reports:
      cobertura: coverage.xml
  needs: [build-test]

deploy:
  image: $CI_REGISTRY_IMAGE/utils:latest
  stage: deploy
  <<: *use_scripts
  script: ./scripts/deploy
  environment:
    name: review/$CI_COMMIT_REF_NAME
    url: https://$STACK_NAME.cc25.chasacademy.dev/docs
    on_stop: stop_review
  cache:
    key: $CI_COMMIT_REF_SLUG
    paths: [.ci_cache]
  needs: [build-utils, unit-tests]

stop_review:
  image: $CI_REGISTRY_IMAGE/utils:latest
  stage: teardown
  <<: *use_scripts
  script: ./scripts/stop
  environment:
    name: review/$CI_COMMIT_REF_NAME
    action: stop
  when: manual



