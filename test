~/bin/hashwall -b '#111' -f '#222' -s 12 
# theme
hc attr theme.tiling.reset 1
hc attr theme.floating.reset 1

# Färger
hc set frame_border_width 4
hc set frame_border_active_color '#5F8787'  # Aktiva fönster
hc set frame_border_normal_color '#222222'  # Inaktiva fönster

hc attr theme.inner_width 4
hc attr theme.inner_color '#5F8787'  # Inner färg som matchar aktiva fönster
hc attr theme.border_width 4
hc attr theme.floating.border_width 4
hc attr theme.floating.outer_width 4
hc attr theme.floating.outer_color '#222222'  # Yttre färg för flytande fönster

# Dölj titelraden och annan extra stil
hc attr theme.title_height 0
hc set frame_bg_transparent 1
hc set frame_bg_normal_color '#00000000'
hc set frame_bg_active_color '#00000000'
hc set always_show_frame 1

# Övriga inställningar
hc set window_gap 20
hc set frame_padding 0
hc set smart_window_surroundings 0
hc set smart_frame_surroundings 1
hc set mouse_recenter_gap 0
hc set focus_follows_mouse 1
hc set focus_stealing_prevention 1
