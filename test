# theme
 hc attr theme.tiling.reset 1
 hc attr theme.floating.reset 1
 hc set frame_border_width 0
 hc set always_show_frame 1
 hc set frame_bg_transparent 1
 hc set frame_gap 30

 hc attr theme.title_height 0
 hc attr theme.padding_right 0
 hc attr theme.padding_left 0
 hc attr theme.padding_bottom 0
 hc attr theme.active.color '#b8b265'
 hc attr theme.normal.color '#1f1f19'
 hc attr theme.padding_top 15

 hc set window_gap 50
 hc set smart_window_surroundings 0
 hc set smart_frame_surroundings 1
 hc set mouse_recenter_gap 0

hc set snap_distance 14
hc set snap_gap 9
hc set snap_to_edge 1
