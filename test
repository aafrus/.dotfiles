# THEME
hc set frame_border_active_color    '#33312B'  # matchar color0 (moss svart)
hc set frame_border_normal_color    '#38362F'  # matchar color8 (moss bright black)
hc set frame_bg_normal_color        '#080808'  # matchar moss bakgrundsfärg
hc set frame_bg_active_color        '#080808'  # matchar moss bakgrundsfärg
hc set frame_border_width           0
hc set always_show_frame            0
hc set frame_bg_transparent         1
hc set frame_transparent_width      0
hc set frame_gap                    6
hc attr theme.padding_top           15 
hc attr theme.active.color          '#CCC5AD'  # matchar moss foreground (vit)
hc attr theme.normal.color          '#707746'  # matchar moss green
hc attr theme.urgent.color          '#BEC35C'  # matchar moss red
hc attr theme.inner_width           1
hc attr theme.outer_width           0
hc attr theme.inner_color           '#33312B'  # matchar color0 (moss svart)
hc attr theme.border_width          0
hc attr theme.floating.border_width 0
hc attr theme.floating.outer_width  0
hc attr theme.floating.inner_width  1
hc attr theme.floating.inner_color  '#38362F'  # matchar color8 (moss bright black)
hc attr theme.floating.outer_color  '#38362F'  # matchar color8 (moss bright black)
hc attr theme.active.inner_color    '#33312B'  # matchar color0 (moss svart)
hc attr theme.active.outer_color    '#33312B'  # matchar color0 (moss svart)
hc attr theme.normal.inner_color    '#38362F'  # matchar color8 (moss bright black)
hc attr theme.normal.outer_color    '#38362F'  # matchar color8 (moss bright black)
hc attr theme.background_color      '#080808'  # matchar moss bakgrundsfärg
hc set window_gap                   9
hc set frame_padding_top            0
hc set smart_window_surroundings    0
hc set smart_frame_surroundings     1
hc set mouse_recenter_gap           0
