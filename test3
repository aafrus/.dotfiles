#!/usr/bin/env zsh
# --------------------------------------------
# Main configuration file
# Loads all other configs in correct order
# --------------------------------------------

# Load all .zsh files in ~/.dotfiles/zsh/
for config in ~/.dotfiles/zsh/*.zsh; do
  # Skip these files
  [[ "$config" == *".zprofile" ]] && continue
  [[ "$config" == *".zshrc" ]] && continue
  
  # Load each config file
  source "$config"
done

# Load aliases LAST to override everything
source ~/.dotfiles/zsh/alias.zsh

