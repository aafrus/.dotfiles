local M = {}

M.colors = {
  -- Basfärger från referenserna
  bg        = "#0a0a0a",    -- Djup OLED-bakgrund
  bg_light  = "#1a1a1a",    -- Underpaneler
  fg        = "#e0e0e0",    -- Primärtext
  
  -- HUD-accentfärger
  alert     = "#ff3a5c",    -- K D6-varningar
  nav       = "#0088ff",    -- Navigationsblått
  drone     = "#00d4ff",    -- Pilotfish-cyan
  system    = "#00c8a0",    -- Systemstatus
  data      = "#b280ff",    -- Datalila
}

function M.setup()
  local c = M.colors

  -- Syntaxgrupper
  vim.api.nvim_set_hl(0, "Normal",       { fg = c.fg, bg = c.bg })
  vim.api.nvim_set_hl(0, "Comment",      { fg = "#666666", italic = true })

  -- HUD-liknande syntax
  vim.api.nvim_set_hl(0, "Function",     { fg = c.nav, bold = true })    -- Navigationsfunktioner
  vim.api.nvim_set_hl(0, "Keyword",      { fg = c.alert })               -- Kritiska kommandon
  vim.api.nvim_set_hl(0, "String",       { fg = c.system })              -- Systemmeddelanden
  vim.api.nvim_set_hl(0, "Number",       { fg = "#ffac38" })             -- Kvantiteter (gult)
  vim.api.nvim_set_hl(0, "Type",         { fg = c.drone })               -- Drönardata

  -- Gränssnittselement
  vim.api.nvim_set_hl(0, "CursorLine",   { bg = c.bg_light })
  vim.api.nvim_set_hl(0, "LineNr",       { fg = "#444444" })
  vim.api.nvim_set_hl(0, "CursorLineNr", { fg = c.drone, bold = true })  -- Cyan som drönarskärm
  vim.api.nvim_set_hl(0, "StatusLine",   { bg = c.nav, fg = c.bg })      -- Navigationspanel

  -- Diagnostic (som systemvarningar)
  vim.api.nvim_set_hl(0, "DiagnosticError",  { fg = c.alert })
  vim.api.nvim_set_hl(0, "DiagnosticWarn",   { fg = "#ffac38" })
  vim.api.nvim_set_hl(0, "DiagnosticInfo",   { fg = c.drone })
  vim.api.nvim_set_hl(0, "DiagnosticHint",   { fg = c.system })
end

return M
