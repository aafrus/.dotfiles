#!/bin/bash
set -eo pipefail

# Snabbautentisering med cache
[ -z "$PORTAINER_TOKEN" ] && {
  source ./scripts/auth.sh
  echo "export PORTAINER_TOKEN=$PORTAINER_TOKEN" >> .ci_cache
}

# Effektiv stackhantering
envsubst <docker-compose.yml >$COMPOSE_FILE
source ./scripts/stack.sh

# Cacha relevanta variabler
echo "export STACK_ID=$STACK_ID" >> .ci_cache

auth.sh (Autentisering)
bash
Copy

#!/bin/bash
export PORTAINER_TOKEN=$(curl -sS -X POST "$PORTAINER_URL/api/auth" \
  --json '{"username":"'$PORTAINER_USER'","password":"'$PORTAINER_PASSWORD'"}' \
  | jq -r '.jwt')

export ENDPOINT_ID=$(curl -sS "$PORTAINER_URL/api/endpoints" \
  -H "Authorization: Bearer $PORTAINER_TOKEN" \
  | jq -r '.[] | select(.Name=="primary").Id')

stack.sh (Stackhantering)
bash
Copy

#!/bin/bash
STACK_ID=$(curl -sS "$PORTAINER_URL/api/stacks" \
  -H "Authorization: Bearer $PORTAINER_TOKEN" \
  | jq -r --arg name "$STACK_NAME" '.[] | select(.Name==$name) | .Id')

if [ -z "$STACK_ID" ]; then
  curl -sS -X POST "$PORTAINER_URL/api/stacks/create/swarm/file?endpointId=$ENDPOINT_ID" \
    -H "Authorization: Bearer $PORTAINER_TOKEN" \
    -F Name="$STACK_NAME" \
    -F SwarmID="$SWARM_ID" \
    -F file=@$COMPOSE_FILE | jq
else
  curl -sS -X PUT "$PORTAINER_URL/api/stacks/$STACK_ID?endpointId=$ENDPOINT_ID" \
    -H "Authorization: Bearer $PORTAINER_TOKEN" \
    --json @<(jq -n --arg content "$(cat $COMPOSE_FILE)" \
    '{"prune":true,"pullImage":true,"stackFileContent":$content}') | jq
fi

