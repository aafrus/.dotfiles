#!/usr/bin/env zsh

git_current_branch() {
  # Moderna git har --show-current, men vi gör det kompatibelt
  git symbolic-ref --short HEAD 2>/dev/null || {
    echo "ERROR: Not on any branch (detached HEAD)" >&2
    return 1
  }
}



alias gpsu='{ branch=$(git_current_branch) || exit 1; git push --set-upstream origin "$branch"; }'
