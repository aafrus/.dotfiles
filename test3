vim.keymap.set("n", "<C-k>", "<C-w>k", {desc = "Flytta till övre split"})
vim.keymap.set("n", "<C-l>", "<C-w>l", {desc = "Flytta till höger split"})

-- Stäng buffer utan att stänga fönster
vim.keymap.set("n", "<C-w>", "<cmd>bdelete<cr>", {desc = "Stäng buffer"})

