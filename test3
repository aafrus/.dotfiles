#!/bin/bash
STACK_ID=$(curl -sSf "$PORTAINER_URL/api/stacks" \
  -H "Authorization: Bearer $PORTAINER_TOKEN" \
  | jq -r --arg name "$STACK_NAME" '.[] | select(.Name==$name) | .Id')

if [[ -z "$STACK_ID" ]]; then
  curl -sSf -X POST "$PORTAINER_URL/api/stacks/create/swarm/file?endpointId=$ENDPOINT_ID" \
    -H "Authorization: Bearer $PORTAINER_TOKEN" \
    -F Name="$STACK_NAME" \
    -F SwarmID="$SWARM_ID" \
    -F file=@deployable-compose.yml | jq
else
  curl -sSf -X PUT "$PORTAINER_URL/api/stacks/$STACK_ID?endpointId=$ENDPOINT_ID" \
    -H "Authorization: Bearer $PORTAINER_TOKEN" \
    --json @<(jq -n --arg content "$(cat deployable-compose.yml)" \
    '{"prune":true,"pullImage":true,"stackFileContent":$content}')
fi

echo "export STACK_ID=$STACK_ID"

