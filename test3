1. .gitlab-ci.yml (Ultrakompakt version)
yaml
Copy

stages: [build, test, deploy, teardown]

variables:
  DOCKER_TAG: $([ "$CI_COMMIT_BRANCH" = "$CI_DEFAULT_BRANCH" ] && echo "latest" || echo "$CI_COMMIT_REF_NAME")
  STACK_NAME: "$CI_PROJECT_PATH_SLUG-$CI_COMMIT_REF_SLUG"
  COMPOSE_FILE: "deployable-compose.yml"

.use_scripts: &use_scripts
  before_script:
    - chmod +x ./scripts/*.sh
    - [ -f "./.ci_cache" ] && source ./.ci_cache

.build_template: &build_config
  image: docker:20
  stage: build
  <<: *use_scripts
  script: ./scripts/build.sh
  rules:
    changes: [Dockerfile, "*.py", requirements*]

build-api:
  <<: *build_config
  variables:
    TARGET: "base"
    TAG: "$DOCKER_TAG"

build-test:
  <<: *build_config
  variables:
    TARGET: "test"
    TAG: "test-$DOCKER_TAG"
  stage: test

deploy:
  image: $CI_REGISTRY_IMAGE/utils:latest
  stage: deploy
  <<: *use_scripts
  script: ./scripts/deploy.sh
  environment:
    name: review/$CI_COMMIT_REF_NAME
    url: https://$STACK_NAME.cc25.chasacademy.dev/docs
    on_stop: stop_review
  cache:
    key: $CI_COMMIT_REF_SLUG
    paths: [.ci_cache]

stop_review:
  image: $CI_REGISTRY_IMAGE/utils:latest
  stage: teardown
  script: ./scripts/stop.sh
  when: manual

