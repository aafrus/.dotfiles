#!/usr/bin/env zsh

git_current_branch() {
  # Get current branch or "detached" if in HEAD
  local branch
  branch=$(git symbolic-ref --short HEAD 2>/dev/null)
  [[ -n "$branch" ]] && echo "$branch" || echo "detached"
}

git_main_branch() {
  # Detect main branch (main/master or custom GitFlow)
  local branch
  branch=$(git config --get gitflow.branch.main 2>/dev/null)
  [[ -z "$branch" ]] && branch=$(git branch -l | grep -E '^\*? *(main|master)' | sed 's/^* *//;q')
  echo "${branch:-main}"
}

grename() {
  # Rename branch locally and remotely
  [[ $# -ne 2 ]] && echo "Usage: grename <old> <new>" && return 1
  git branch -m "$1" "$2"
  git push origin --delete "$1"
  git push origin -u "$2"
}

