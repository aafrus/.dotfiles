#!/bin/bash
set -eo pipefail

# Parse arguments
while [[ "$#" -gt 0 ]]; do
    case $1 in
        -f|--file) DOCKERFILE="$2"; shift ;;
        -t|--target) TARGET="$2"; shift ;;
        --tag) TAG="$2"; shift ;;
        *) echo "Unknown parameter: $1"; exit 1 ;;
    esac
    shift
done

docker buildx build \
  --cache-from=$CI_REGISTRY_IMAGE:latest \
  -t $CI_REGISTRY_IMAGE:${TAG:-latest} \
  --push \
  --target=${TARGET:-base} \
  -f ${DOCKERFILE:-Dockerfile} .

