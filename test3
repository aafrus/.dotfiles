gpsu() {
  if ! branch=$(git_current_branch); then
    echo "Error: You're in detached HEAD state. Checkout a branch first." >&2
    return 1
  fi

  if [[ "$branch" == "main" || "$branch" == "master" ]]; then
    echo "Error: Direct pushes to main/master are blocked. Create a feature branch." >&2
    return 1
  fi

  git push --set-upstream origin "$branch"
}

branch=$(git branch --show-current 2>/dev/null) && git push --set-upstream origin "$branch"
