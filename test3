#!/usr/bin/env zsh

# [1] Load env FIRST
source ~/.dotfiles/zsh/env.zsh

# [2] Setup function path and AUTOLOAD
fpath=( ~/.dotfiles/zsh/functions "${fpath[@]}" )
autoload -Uz git_current_branch git_main_branch grename  # Ladda EXPLICIT

# [3] Load other configs
for config in ~/.dotfiles/zsh/*.zsh; do
  [[ "$config" == *"env.zsh" ]] && continue
  [[ "$config" == *"alias.zsh" ]] && continue
  [[ "$config" == *".zprofile" ]] && continue
  [[ "$config" == *".zshrc" ]] && continue
  source "$config"
done

# [4] Load aliases LAST
source ~/.dotfiles/zsh/alias.zsh



git_current_branch() { git branch --show-current 2>/dev/null || echo "detached"; }



