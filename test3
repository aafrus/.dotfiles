#!/usr/bin/env zsh
# --------------------------------------------
# Git Functions
# --------------------------------------------

git_current_branch() {
  # Use modern git command (faster)
  git branch --show-current 2>/dev/null || echo "detached"
}

git_main_branch() {
  # Check gitflow config first, then detect
  local branch
  branch=${GITFLOW_MAIN_BRANCH:-$(git config gitflow.branch.main)}
  branch=${branch:-$(git branch -l | grep -E '^\*? *(main|master)' | head -1 | sed 's/^* *//')}
  echo "${branch:-main}"
}

grename() {
  # Safer branch rename with checks
  if [[ $# -ne 2 ]]; then
    echo "Usage: ${0[9,-1]} <old-branch> <new-branch>" >&2
    return 1
  fi
  
  if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo "Not a git repository" >&2
    return 1
  fi
  
  git branch -m "$1" "$2" && \
  git push origin --delete "$1" 2>/dev/null && \
  git push origin -u "$2"
}





