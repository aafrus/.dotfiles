-- init.lua

-- Grundinställningar
vim.opt.number = true             -- radnummer
vim.opt.relativenumber = true     -- relativt radnummer
vim.opt.clipboard = "unnamedplus" -- kopiera/klistra till systemet
vim.opt.mouse = "a"               -- möjliggör mus
vim.opt.termguicolors = true      -- färg
vim.opt.cursorline = true         -- highlight på nuvarande rad
vim.opt.scrolloff = 8             -- luft ovan/nedanför kursorn
vim.opt.splitright = true         -- ny split till höger
vim.opt.splitbelow = true         -- ny split nedåt
vim.opt.ignorecase = true         -- case-insensitiv sökning
vim.opt.smartcase = true          -- case-sensitiv vid stor bokstav
vim.opt.updatetime = 300          -- snabbare git-gutter etc
vim.opt.expandtab = true          -- tabs blir mellanslag
vim.opt.shiftwidth = 2            -- antal mellanslag för autoindent
vim.opt.tabstop = 2               -- antal mellanslag ett tabb representerar
