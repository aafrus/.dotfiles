Lägg en minimal init.lua där (vi skippar .vimrc, det är 2025):

-- ~/.config/nvim/init.lua

vim.opt.number = true             -- radnummer
vim.opt.relativenumber = true     -- relativt radnummer
vim.opt.clipboard = "unnamedplus" -- kopiera/klistra till systemet
vim.opt.mouse = "a"               -- möjliggör mus
vim.opt.termguicolors = true      -- färg
vim.opt.cursorline = true         -- highlight på nuvarande rad
vim.opt.scrolloff = 8             -- luft ovan/nedanför kursorn
vim.opt.splitright = true
vim.opt.splitbelow = true
vim.opt.ignorecase = true
vim.opt.smartcase = true
vim.opt.updatetime = 300

vim.g.mapleader = " "

-- Mappings
vim.keymap.set("n", "<C-s>", ":w<CR>")
vim.keymap.set("i", "<C-s>", "<Esc>:w<CR>")

-- Plugins (börjar enkelt, vi tar Packer)
require("plugin-bootstrap")

🧪 Steg 2: Plugin manager

Vi kör Packer.
Kör detta i terminalen:

git clone --depth 1 https://github.com/wbthomason/packer.nvim\
 ~/.local/share/nvim/site/pack/packer/start/packer.nvim

Sen i din ~/.config/nvim/plugin-bootstrap.lua:

-- plugin-bootstrap.lua

vim.cmd [[packadd packer.nvim]]

require('packer').startup(function()
  use 'wbthomason/packer.nvim' -- Packer hanterar sig själv

  -- Teman
  use 'folke/tokyonight.nvim'

  -- Filträd
  use {
    'nvim-tree/nvim-tree.lua',
    requires = 'nvim-tree/nvim-web-devicons'
  }

  -- Fuzzy finder
  use {
    'nvim-telescope/telescope.nvim',
    requires = { {'nvim-lua/plenary.nvim'} }
  }

  -- Status line
  use 'nvim-lualine/lualine.nvim'
end)

I nvim, kör:

:PackerSync

🧪 Steg 3: Göra det skönt

Lägg till i init.lua:

-- Tema
vim.cmd[[colorscheme tokyonight]]

-- Lualine
require('lualine').setup()

-- NvimTree toggle
vim.keymap.set("n", "<leader>e", ":NvimTreeToggle<CR>")

-- Telescope find files
vim.keymap.set("n", "<leader>ff", ":Telescope find_files<CR>")
vim.keymap.set("n", "<leader>fg", ":Telescope live_grep<CR>")

