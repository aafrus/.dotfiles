#!/bin/sh

userresources=$HOME/.Xresources
usermodmap=$HOME/.Xmodmap
sysresources=/etc/X11/xinit/.Xresources
sysmodmap=/etc/X11/xinit/.Xmodmap

# merge in defaults and keymaps

if [ -f $sysresources ]; then







    xrdb -merge $sysresources

fi

if [ -f $sysmodmap ]; then
    xmodmap $sysmodmap
fi

if [ -f "$userresources" ]; then







    xrdb -merge "$userresources"

fi

if [ -f "$usermodmap" ]; then
    xmodmap "$usermodmap"
fi

# start programs

if [ -d /etc/X11/xinit/xinitrc.d ] ; then
 for f in /etc/X11/xinit/xinitrc.d/?*.sh ; do
  [ -x "$f" ] && . "$f"
 done
 unset f
fi

#wallpaper
#feh --bg-scale ~/hub/pictures/wall.jpg
xsetroot -solid '#000000'

#cursor
xsetroot -cursor_name left_ptr &
unclutter -idle 1 &

#load resources
xrdb -load ~/.config/urxvt/.Xdefaults

#set monitor
xrandr --output Virtual-1 --mode 1920x1080

#keyboard
setxkbmap se -variant latin1

#never sleep 
xset s off
xset -dpms
xset s noblank               

#dunst 
dunst &
# start urxvtd
urxvtd -q -o -f

#start wm
exec herbstluftwm


Det låter som vi behöver justera din prompt och kontrollera aliasen. Här är lösningen:
1. Fixa blixtsymbolen (⚡) i hemkatalogen

Ändra i ~/.dotfiles/zsh/prompt.zsh:
zsh
Copy

# ---[ Git Status Check ]---
git_prompt_info() {
    # Only show in Git repos
    [[ -n $(git rev-parse --is-inside-work-tree 2>/dev/null) ]] || return
    
    local ref dirty stat
    ref=$(git symbolic-ref --short HEAD 2>/dev/null || 
          git describe --tags --exact-match HEAD 2>/dev/null) || return

    # Dirty check (⚡ only shows in dirty repos)
    git diff --quiet --ignore-submodules 2>/dev/null || dirty=" ⚡"

    # Upstream status
    case $(git rev-list --count --left-right @{upstream}...HEAD 2>/dev/null) in
        "") ;;       # No upstream
        "0"*) ;;     # Equal
        *"0") stat=" ▲" ;;   # Ahead
        *) stat=" ▼" ;;      # Behind
    esac

    echo "%F{241}[%F{244}${ref}${dirty}${stat}%F{241}]"
}

2. Fixa bat aliaset

Redigera ~/.dotfiles/zsh/aliases.zsh:
zsh
Copy

# ---[ File Viewing ]---
alias bat='bat --theme=TwoDark --style=header,grid'
alias cat='bat --pager=never'
alias ls='exa --group-directories-first --icons'
alias ll='exa -l --group-directories-first --icons --git'
alias tree='exa --tree --level=2'

3. Fixa cd-beteendet

Lägg till detta i ~/.dotfiles/zsh/plugins.zsh:
zsh
Copy

# ---[ Directory Navigation ]---
autoload -Uz chpwd_recent_dirs cdr
setopt auto_cd
setopt cdable_vars

# Auto-ls after cd
chpwd() {
    emulate -L zsh
    exa --group-directories-first --icons
}

4. Verifiera att allt fungerar
bash
Copy

# Ladda om konfigurationen
exec zsh

# Testa:
cd ~/some_directory  # Borde visa innehåll automatiskt
git status           # Borde inte visa ⚡ i icke-Git-mappar
bat aliases.zsh      # Borde visa filen med syntaxfärgning

