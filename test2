local M = {}

M.colors = {
  black     = "#000000",
  white     = "#ffffff",
  gray_dark = "#121212",
  gray      = "#444444",
  gray_light= "#888888",
  accent    = "#5f875f"  -- Muted grön
}

function M.load()
  local c = M.colors

  -- Registrera först temat
  vim.g.colors_name = "blackmetal"

  -- Grundinställningar
  vim.api.nvim_set_hl(0, "Normal",       { fg = c.white, bg = c.black })
  vim.api.nvim_set_hl(0, "Comment",      { fg = c.gray, italic = true })

  -- Syntax
  vim.api.nvim_set_hl(0, "Function",     { fg = c.white, bold = true })
  vim.api.nvim_set_hl(0, "Keyword",      { fg = c.white, bold = true })
  vim.api.nvim_set_hl(0, "String",       { fg = c.gray_light })
  vim.api.nvim_set_hl(0, "Number",       { fg = c.white })
  vim.api.nvim_set_hl(0, "Type",         { fg = c.accent })

  -- Gränssnitt
  vim.api.nvim_set_hl(0, "CursorLine",   { bg = c.gray_dark })
  vim.api.nvim_set_hl(0, "LineNr",       { fg = c.gray })
  vim.api.nvim_set_hl(0, "CursorLineNr", { fg = c.accent, bold = true })
  vim.api.nvim_set_hl(0, "StatusLine",   { bg = c.gray_dark, fg = c.white })
end

return M
