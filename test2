local M = {}

M.colors = {
  black     = "#000000",
  white     = "#ffffff",
  gray_dark = "#121212",
  gray      = "#444444",
  gray_light= "#888888",
  accent    = "#5f875f"
}

function M.load()
  -- Först rensa alla befintliga highlights
  vim.cmd("hi clear")
  if vim.fn.exists("syntax_on") == 1 then
    vim.cmd("syntax reset")
  end

  local c = M.colors

  -- Måste sätta colors_name INNAN highlights
  vim.g.colors_name = "blackmetal"

  -- Grundinställningar
  vim.api.nvim_set_hl(0, "Normal",       { fg = c.white, bg = c.black })
  vim.api.nvim_set_hl(0, "Comment",      { fg = c.gray, italic = true })

  -- Syntax
  vim.api.nvim_set_hl(0, "Function",     { fg = c.white, bold = true })
  vim.api.nvim_set_hl(0, "Keyword",      { fg = c.white, bold = true })
  vim.api.nvim_set_hl(0, "String",       { fg = c.gray_light })
  vim.api.nvim_set_hl(0, "Number",       { fg = c.white })
  vim.api.nvim_set_hl(0, "Type",         { fg = c.accent })

  -- Gränssnitt
  vim.api.nvim_set_hl(0, "CursorLine",   { bg = c.gray_dark })
  vim.api.nvim_set_hl(0, "LineNr",       { fg = c.gray })
  vim.api.nvim_set_hl(0, "CursorLineNr", { fg = c.accent, bold = true })
  vim.api.nvim_set_hl(0, "StatusLine",   { bg = c.gray_dark, fg = c.white })
end

return M


-- Ladda och aktivera temat
vim.opt.termguicolors = true
local status, _ = pcall(require, 'plugins.theme')
if status then
  require('plugins.theme').load()
  vim.cmd("colorscheme blackmetal")
else
  vim.notify("Failed to load blackmetal theme", vim.log.levels.ERROR)
end
