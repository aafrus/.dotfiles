~/.config/nvim/lua/2049.lua

local M = {}

M.default = {
  -- Basfärger
  bg        = "#000000",  -- Svart som LAPD-skärmar
  bg_light  = "#111111",  -- Systemdelar
  fg        = "#ffffff",  -- Primärtext
  fg_dim    = "#666666",  -- Sekundärinformation

  -- Funktionella färger
  nav_blue  = "#0066ff",  -- Navigationsblå
  alert_red = "#ff0000",  -- Kritisk status
  ok_green  = "#00ff00",  -- System OK
  warn_yellow = "#ffff00",-- Varning

  -- Datafärger
  data_cyan = "#00ffff",  -- Strömmar
  system_magenta = "#ff00ff" -- Kärnsystem
}

function M.setup()
  local c = M.default

  -- Bas
  vim.api.nvim_set_hl(0, "Normal",       { fg = c.fg, bg = c.bg })
  vim.api.nvim_set_hl(0, "Comment",      { fg = c.fg_dim, italic = false })

  -- Syntax (minimalistisk)
  vim.api.nvim_set_hl(0, "Function",     { fg = c.nav_blue, bold = true })  -- Navigationsfunktioner
  vim.api.nvim_set_hl(0, "Keyword",      { fg = c.alert_red })              -- Kritiska kommandon
  vim.api.nvim_set_hl(0, "String",       { fg = c.ok_green })               -- Systemmeddelanden
  vim.api.nvim_set_hl(0, "Number",       { fg = c.warn_yellow })            -- Kvantiteter
  vim.api.nvim_set_hl(0, "Type",         { fg = c.system_magenta })         -- Systemtyper

  -- Användargränssnitt
  vim.api.nvim_set_hl(0, "CursorLine",   { bg = c.bg_light })
  vim.api.nvim_set_hl(0, "LineNr",       { fg = c.fg_dim })
  vim.api.nvim_set_hl(0, "CursorLineNr", { fg = c.nav_blue, bold = true })
  vim.api.nvim_set_hl(0, "Pmenu",        { bg = c.bg_light, fg = c.fg })

  -- Statuslinje (HUD-liknande)
  vim.api.nvim_set_hl(0, "StatusLine",   { bg = c.nav_blue, fg = c.bg })
  vim.api.nvim_set_hl(0, "StatusLineNC", { bg = c.bg_light, fg = c.fg_dim })

  -- Diagnostic (Pilotfish-scanning)
  vim.api.nvim_set_hl(0, "DiagnosticError",  { fg = c.alert_red, bg = c.bg })
  vim.api.nvim_set_hl(0, "DiagnosticWarn",   { fg = c.warn_yellow })
  vim.api.nvim_set_hl(0, "DiagnosticInfo",   { fg = c.nav_blue })
  vim.api.nvim_set_hl(0, "DiagnosticHint",   { fg = c.ok_green })
end

return M
