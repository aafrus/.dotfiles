#!/bin/sh

userresources=$HOME/.Xresources
usermodmap=$HOME/.Xmodmap
sysresources=/etc/X11/xinit/.Xresources
sysmodmap=/etc/X11/xinit/.Xmodmap

# merge in defaults and keymaps

if [ -f $sysresources ]; then







    xrdb -merge $sysresources

fi

if [ -f $sysmodmap ]; then
    xmodmap $sysmodmap
fi

if [ -f "$userresources" ]; then







    xrdb -merge "$userresources"

fi

if [ -f "$usermodmap" ]; then
    xmodmap "$usermodmap"
fi

# start programs

if [ -d /etc/X11/xinit/xinitrc.d ] ; then
 for f in /etc/X11/xinit/xinitrc.d/?*.sh ; do
  [ -x "$f" ] && . "$f"
 done
 unset f
fi

#wallpaper
#feh --bg-scale ~/hub/pictures/wall.jpg
xsetroot -solid '#000000'

#cursor
xsetroot -cursor_name left_ptr &
unclutter -idle 1 &

#load resources
xrdb -load ~/.config/urxvt/.Xdefaults

#set monitor
xrandr --output Virtual-1 --mode 1920x1080

#keyboard
setxkbmap se -variant latin1

#never sleep 
xset s off
xset -dpms
xset s noblank               

#dunst 
dunst &
# start urxvtd
urxvtd -q -o -f

#start wm
exec herbstluftwm




# ------ [ Core Setup ] ------
autoload -Uz colors && colors
setopt PROMPT_SUBST

# ------ [ Git Symbols ] ------
ICO_DIRTY="✗"          # Osaved changes
ICO_STAGED="+"         # Staged changes
ICO_UNTRACKED="?"      # New files
ICO_STASHED="⚑"        # Stashes exist
ICO_AHEAD="↑"          # Ahead of remote
ICO_BEHIND="↓"         # Behind remote
ICO_DIVERGED="↕"       # Diverged from remote
ICO_CLEAN="✓"          # Clean branch

# ------ [ Colors ] ------
COLOR_BRANCH="%F{magenta}"
COLOR_DIR="%F{blue}"
COLOR_CHANGES="%F{red}"
COLOR_STAGED="%F{yellow}"
COLOR_CLEAN="%F{green}"

# ------ [ Main Prompt (Left) ] ------
PROMPT='%F{11}───── %f%F{15}%~%f '  # Behåll din minimalistiska stil

# ------ [ Git Powerprompt (Right) ] ------
RPROMPT='$(git_super_status)'

# ------ [ Git Status Function ] ------
git_super_status() {
  local branch=$(git symbolic-ref --short HEAD 2>/dev/null)
  [[ -z "$branch" ]] && return

  # ---- [ Local Status ] ----
  local changes="" staged="" untracked="" stashed=""
  
  # Dirty check (faster than git status)
  git diff --quiet --ignore-submodules 2>/dev/null || changes=$ICO_DIRTY
  git diff --cached --quiet --ignore-submodules 2>/dev/null || staged=$ICO_STAGED
  [[ -n $(git ls-files --others --exclude-standard) ]] && untracked=$ICO_UNTRACKED
  [[ $(git stash list | wc -l) -gt 0 ]] && stashed=$ICO_STASHED

  # ---- [ Remote Status ] ----
  local ahead=0 behind=0 diverged=""
  git rev-parse --abbrev-ref @{u} &>/dev/null && {
    ahead=$(git rev-list @{u}..HEAD --count 2>/dev/null)
    behind=$(git rev-list HEAD..@{u} --count 2>/dev/null)
    [[ $ahead -gt 0 && $behind -gt 0 ]] && diverged=$ICO_DIVERGED
  }

  # ---- [ Formatting ] ----
  echo "${COLOR_BRANCH}[${branch}${COLOR_CHANGES}${changes}${COLOR_STAGED}${staged}${untracked}${stashed}"\
  "${diverged}${ahead:+$ICO_AHEAD$ahead}${behind:+$ICO_BEHIND$behind}${COLOR_BRANCH}]%f"
}

# ------ [ Auto-Refresh ] ------
autoload -Uz add-zsh-hook
add-zsh-hook precmd {
  git rev-parse --is-inside-work-tree &>/dev/null && git fetch --quiet &!
}


plugins.zsh

# ------ [ Zinit Setup ] ------
ZINIT_HOME="${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git"
[[ ! -f "$ZINIT_HOME/zinit.zsh" ]] && git clone --depth 1 https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
source "${ZINIT_HOME}/zinit.zsh"

