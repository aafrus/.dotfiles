~/.config/nvim/lua/bladerunner.lua

local M = {}

local hsl = function(h, s, l)
  local hex = require("vesper.hsl").hslToHex(h, s, l)
  return hex:upper()
end

---@class Palette
M.default = {
  none = "NONE",
  bg = hsl(240, 30, 5),       -- #0a0a12
  bg_dark = hsl(240, 30, 8),  -- #121220
  bg_light = hsl(240, 20, 12),-- #1a1a2e
  
  fg = hsl(0, 0, 88),         -- #e0e0e0
  fg_dark = hsl(0, 0, 60),    -- #999999
  
  -- Neon accents
  neon_pink = hsl(340, 100, 59),  -- #ff2a6d
  neon_cyan = hsl(185, 92, 56),   -- #05d9e8
  neon_blue = hsl(198, 85, 70),   -- #75d1f0
  
  -- Syntaxgrupper
  red = hsl(355, 80, 60),
  orange = hsl(20, 100, 60),
  yellow = hsl(45, 100, 60),
  green = hsl(120, 60, 55),
  purple = hsl(290, 80, 70),
}

function M.setup()
  local colors = M.default
  
  -- Base
  vim.api.nvim_set_hl(0, "Normal", { fg = colors.fg, bg = colors.bg })
  vim.api.nvim_set_hl(0, "Comment", { fg = colors.fg_dark, italic = true })

  -- Syntax
  vim.api.nvim_set_hl(0, "Function", { fg = colors.neon_cyan, bold = true })
  vim.api.nvim_set_hl(0, "Keyword", { fg = colors.neon_pink })
  vim.api.nvim_set_hl(0, "String", { fg = colors.neon_blue })
  vim.api.nvim_set_hl(0, "Number", { fg = colors.yellow })
  vim.api.nvim_set_hl(0, "Type", { fg = colors.neon_cyan })

  -- UI
  vim.api.nvim_set_hl(0, "CursorLine", { bg = colors.bg_dark })
  vim.api.nvim_set_hl(0, "LineNr", { fg = colors.fg_dark })
  vim.api.nvim_set_hl(0, "CursorLineNr", { fg = colors.neon_pink, bold = true })
  vim.api.nvim_set_hl(0, "PmenuSel", { bg = colors.neon_pink, fg = colors.bg })

  -- LSP
  vim.api.nvim_set_hl(0, "DiagnosticError", { fg = colors.red })
  vim.api.nvim_set_hl(0, "DiagnosticWarn", { fg = colors.orange })
  vim.api.nvim_set_hl(0, "DiagnosticInfo", { fg = colors.neon_cyan })
  vim.api.nvim_set_hl(0, "DiagnosticHint", { fg = colors.purple })

  -- Treesitter (om du använder det)
  vim.api.nvim_set_hl(0, "@property", { fg = colors.neon_blue })
  vim.api.nvim_set_hl(0, "@variable", { fg = colors.fg })
end

return M
