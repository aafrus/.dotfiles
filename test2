#!/bin/sh

userresources=$HOME/.Xresources
usermodmap=$HOME/.Xmodmap
sysresources=/etc/X11/xinit/.Xresources
sysmodmap=/etc/X11/xinit/.Xmodmap

# merge in defaults and keymaps

if [ -f $sysresources ]; then







    xrdb -merge $sysresources

fi

if [ -f $sysmodmap ]; then
    xmodmap $sysmodmap
fi

if [ -f "$userresources" ]; then







    xrdb -merge "$userresources"

fi

if [ -f "$usermodmap" ]; then
    xmodmap "$usermodmap"
fi

# start programs

if [ -d /etc/X11/xinit/xinitrc.d ] ; then
 for f in /etc/X11/xinit/xinitrc.d/?*.sh ; do
  [ -x "$f" ] && . "$f"
 done
 unset f
fi

#wallpaper
#feh --bg-scale ~/hub/pictures/wall.jpg
xsetroot -solid '#000000'

#cursor
xsetroot -cursor_name left_ptr &
unclutter -idle 1 &

#load resources
xrdb -load ~/.config/urxvt/.Xdefaults

#set monitor
xrandr --output Virtual-1 --mode 1920x1080

#keyboard
setxkbmap se -variant latin1

#never sleep 
xset s off
xset -dpms
xset s noblank               

#dunst 
dunst &
# start urxvtd
urxvtd -q -o -f

#start wm
exec herbstluftwm


1. Rensa upp kaoset:
bash
Copy

# Ta bort alla trasiga länkar/filer
rm -f ~/.zshrc ~/.zprofile ~/env.zsh ~/security.zsh

# Återställ backup om du har någon
[ -d ~/.config/zsh.bak ] && mv ~/.config/zsh.bak/* ~/.dotfiles/zsh/

2. Skapa den perfekta strukturen:
bash
Copy

# Skapa mappen (om den inte finns)
mkdir -p ~/.dotfiles/zsh

# Flytta ALL din ZSH-konfig hit:
mv ~/.config/zsh/*.zsh ~/.dotfiles/zsh/ 2>/dev/null || echo "Inga filer att flytta"
mv ~/.zshrc ~/.zprofile ~/.dotfiles/zsh/ 2>/dev/null || echo "Inga filer att flytta"

Nu ska din ~/.dotfiles/zsh/ se ut exakt så här:
Copy

~/.dotfiles/zsh/
├── .zprofile          # [[ -z $DISPLAY && $XDG_VTNR -eq 1 ]] && startx
├── .zshrc             # Huvudfil (se nedan)
├── aliases.zsh        # Alla dina alias
├── completion.zsh     # Tab-completion
├── env.zsh            # Miljövariabler (EDITOR, PATH etc)
├── history.zsh        # HISTSIZE-inställningar
├── keys.zsh           # Tangentbordsbindningar
├── plugins.zsh        # Zinit-plugins
├── prompt.zsh         # Din prompt
└── security.zsh       # Säkerhetsaliases

3. Skapa huvudfilen (~/.dotfiles/zsh/.zshrc):
zsh
Copy

#!/usr/bin/env zsh
# ---[ Load all configs ]---

# Ladda alla .zsh-filer i samma mapp
for config in ~/.dotfiles/zsh/*.zsh; do
  # Exkludera .zprofile och sig själv för att undvika loopar
  [[ "$config" == *".zprofile" ]] && continue
  [[ "$config" == *".zshrc" ]] && continue
  source "$config"
done

4. Skapa symlinks (manuellt enklast):
bash
Copy

ln -sv ~/.dotfiles/zsh/.zshrc ~/.zshrc
ln -sv ~/.dotfiles/zsh/.zprofile ~/.zprofile

(Du behöver inte symlinka andra filer - de laddas via .zshrc!)
5. Testa direkt:
bash
Copy

exec zsh
echo $EDITOR  # Borde visa "nvim" om env.zsh laddades
alias         # Borde visa dina aliases

