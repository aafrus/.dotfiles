-- Use vim.keymap.set for cleaner mapping
local opts = { noremap = true, silent = true }

-- Ctrl+C = copy to system clipboard
vim.keymap.set({'v', 'x'}, '<C-c>', '"+y', opts)

-- Ctrl+V = paste from system clipboard
vim.keymap.set({'n', 'v', 'x'}, '<C-v>', '"+p', opts)

-- Ctrl+X = cut (copy + delete) to system clipboard
vim.keymap.set({'v', 'x'}, '<C-x>', '"+d', opts)



-- Ladda temat FÖRE colorscheme-kommandot
require('plugins.theme').load()

-- Använd temat
vim.cmd.colorscheme('blackmetal')





