# ---[ Completion System ]---
() {
  # Skapa zcompdump-katalog om den inte finns
  local zcompdump="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompdump"
  [[ -d "${zcompdump:h}" ]] || mkdir -p "${zcompdump:h}"
  
  # Ladda compinit säkert
  if autoload -Uz compinit; then
    compinit -u -d "$zcompdump"
  else
    echo "compinit autoload failed!" >&2
    return 1
  fi
}

# ---[ Completion Styles ]---
zstyle ':completion:*' menu no
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'

# ---[ FZF-Tab Integration ]---
if (( ${+commands[fzf]} )); then
  zstyle ':fzf-tab:*' fzf-command ftb-tmux-popup
  zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color=always $realpath'
  zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'ls --color=always $realpath'
fi
