~/.config/nvim/lua/colors.lua

vim.cmd("hi clear")
vim.opt.background = "dark"

local colors = {
  bg       = "#080808",
  fg       = "#e0e0e0",
  gray1    = "#1a1a1a",
  gray2    = "#666666",
  gray3    = "#888888",
  accent1  = "#5f8787",  -- Blågrön (funktioner)
  accent2  = "#87875f",  -- Gulgrön (nyckelord)
  accent3  = "#8181a6"   -- Lila (strängar/special)
}

-- Grunder
vim.api.nvim_set_hl(0, "Normal",       { fg = colors.fg, bg = colors.bg })
vim.api.nvim_set_hl(0, "Comment",      { fg = colors.gray2, italic = true })

-- Syntax
vim.api.nvim_set_hl(0, "Function",     { fg = colors.accent1 })
vim.api.nvim_set_hl(0, "Keyword",      { fg = colors.accent2 })
vim.api.nvim_set_hl(0, "String",       { fg = colors.accent3 })
vim.api.nvim_set_hl(0, "Number",       { fg = colors.fg })
vim.api.nvim_set_hl(0, "Type",         { fg = colors.accent1 })

-- UI
vim.api.nvim_set_hl(0, "LineNr",       { fg = colors.gray2 })
vim.api.nvim_set_hl(0, "CursorLine",   { bg = colors.gray1 })
vim.api.nvim_set_hl(0, "CursorLineNr", { fg = colors.accent1, bold = true })
vim.api.nvim_set_hl(0, "Pmenu",        { bg = colors.gray1, fg = colors.fg })

-- LSP
vim.api.nvim_set_hl(0, "DiagnosticError", { fg = "#d78787" })  -- Lätt röd
vim.api.nvim_set_hl(0, "DiagnosticWarn",  { fg = colors.accent2 })

-- Aktivera temat
vim.cmd("colorscheme custom_minimal")
