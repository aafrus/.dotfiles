#!/bin/sh

userresources=$HOME/.Xresources
usermodmap=$HOME/.Xmodmap
sysresources=/etc/X11/xinit/.Xresources
sysmodmap=/etc/X11/xinit/.Xmodmap

# merge in defaults and keymaps

if [ -f $sysresources ]; then







    xrdb -merge $sysresources

fi

if [ -f $sysmodmap ]; then
    xmodmap $sysmodmap
fi

if [ -f "$userresources" ]; then







    xrdb -merge "$userresources"

fi

if [ -f "$usermodmap" ]; then
    xmodmap "$usermodmap"
fi

# start programs

if [ -d /etc/X11/xinit/xinitrc.d ] ; then
 for f in /etc/X11/xinit/xinitrc.d/?*.sh ; do
  [ -x "$f" ] && . "$f"
 done
 unset f
fi

#wallpaper
#feh --bg-scale ~/hub/pictures/wall.jpg
xsetroot -solid '#000000'

#cursor
xsetroot -cursor_name left_ptr &
unclutter -idle 1 &

#load resources
xrdb -load ~/.config/urxvt/.Xdefaults

#set monitor
xrandr --output Virtual-1 --mode 1920x1080

#keyboard
setxkbmap se -variant latin1

#never sleep 
xset s off
xset -dpms
xset s noblank               

#dunst 
dunst &
# start urxvtd
urxvtd -q -o -f

#start wm
exec herbstluftwm


# ---[ History Settings ]---
export HISTFILE=~/.local/share/zsh/history  # Explicit sökväg
export HISTSIZE=100000
export SAVEHIST=100000

setopt EXTENDED_HISTORY       # Lagra tidstämpel och körtid
setopt SHARE_HISTORY          # Dela historik mellan sessioner
setopt INC_APPEND_HISTORY     # Skriv till fil direkt, inte vid avslut
setopt HIST_IGNORE_ALL_DUPS   # Ta bort duplicerade kommandon
setopt HIST_SAVE_NO_DUPS      # Spara inte duplicerade kommandon
setopt HIST_FIND_NO_DUPS      # Visa inte duplicerade kommandon vid sökning
setopt HIST_REDUCE_BLANKS     # Ta bort onödiga blanksteg
