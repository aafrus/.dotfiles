#!/bin/sh

userresources=$HOME/.Xresources
usermodmap=$HOME/.Xmodmap
sysresources=/etc/X11/xinit/.Xresources
sysmodmap=/etc/X11/xinit/.Xmodmap

# merge in defaults and keymaps

if [ -f $sysresources ]; then







    xrdb -merge $sysresources

fi

if [ -f $sysmodmap ]; then
    xmodmap $sysmodmap
fi

if [ -f "$userresources" ]; then







    xrdb -merge "$userresources"

fi

if [ -f "$usermodmap" ]; then
    xmodmap "$usermodmap"
fi

# start programs

if [ -d /etc/X11/xinit/xinitrc.d ] ; then
 for f in /etc/X11/xinit/xinitrc.d/?*.sh ; do
  [ -x "$f" ] && . "$f"
 done
 unset f
fi

#wallpaper
#feh --bg-scale ~/hub/pictures/wall.jpg
xsetroot -solid '#000000'

#cursor
xsetroot -cursor_name left_ptr &
unclutter -idle 1 &

#load resources
xrdb -load ~/.config/urxvt/.Xdefaults

#set monitor
xrandr --output Virtual-1 --mode 1920x1080

#keyboard
setxkbmap se -variant latin1

#never sleep 
xset s off
xset -dpms
xset s noblank               

#dunst 
dunst &
# start urxvtd
urxvtd -q -o -f

#start wm
exec herbstluftwm
# ---[ Core Environment ]--------------------------------
export EDITOR='nvim'
export VISUAL='nvim'
export PATH="$HOME/.local/bin:/usr/local/bin:$PATH"

# ---[ XDG Base Directories ]----------------------------
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_STATE_HOME="$HOME/.local/state"
export HISTFILE="$XDG_STATE_HOME/zsh/history"

# ---[ Language & Locale ]-------------------------------
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# ---[ LS Colors (för färger i ls) ]---------------------
if command -v dircolors >/dev/null; then      # Linux
    eval "$(dircolors -b)"
elif command -v gdircolors >/dev/null; then   # macOS (med coreutils)
    eval "$(gdircolors -b)"
    alias ls='gls --color=auto'
fi
export CLICOLOR=1                             # macOS/BSD fallback

# ---[ Other Tools ]-------------------------------------
export GOPATH="$HOME/.local/lib/go"
export CARGO_HOME="$HOME/.local/lib/cargo"
export PATH="$PATH:$GOPATH/bin:$CARGO_HOME/bin"

# ---[ Vi Mode (om du vill ha det) ]---------------------
set -o vi
