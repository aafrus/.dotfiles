~/.config/nvim/lua/colors.lua

vim.cmd("hi clear")
vim.opt.background = "dark"

local palette = {
  black     = "#080808",
  blood     = "#8b0000",  -- Primary accent
  blood_drk = "#420d0d",  -- Darker blood
  gray_drk  = "#1a1a1a",
  gray      = "#4e4e4e",
  gray_lt   = "#6a6a6a",
  silver    = "#c0c0c0"
}

-- Base
vim.api.nvim_set_hl(0, "Normal",     {fg = palette.silver, bg = palette.black})
vim.api.nvim_set_hl(0, "Comment",    {fg = palette.gray, italic=true})

-- Syntax
vim.api.nvim_set_hl(0, "Function",   {fg = palette.blood})
vim.api.nvim_set_hl(0, "Keyword",    {fg = palette.blood_drk, bold=true})
vim.api.nvim_set_hl(0, "String",     {fg = palette.gray_lt})
vim.api.nvim_set_hl(0, "Number",     {fg = palette.silver})

-- UI
vim.api.nvim_set_hl(0, "LineNr",           {fg = palette.gray})
vim.api.nvim_set_hl(0, "CursorLine",       {bg = palette.gray_drk})
vim.api.nvim_set_hl(0, "CursorLineNr",     {fg = palette.blood, bold=true})
vim.api.nvim_set_hl(0, "PmenuSel",         {bg = palette.blood_drk})

-- LSP/Debug
vim.api.nvim_set_hl(0, "DiagnosticError",  {fg = palette.blood})
vim.api.nvim_set_hl(0, "DiagnosticWarn",   {fg = palette.blood_drk})

vim.cmd("colorscheme typeonegative")
