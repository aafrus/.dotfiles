#‚Ėą‚Ėď‚Ėí‚ĖĎ requires: imagemagick + hsetroot

usage() {
    echo "usage: `basename $0` [-bfsr]
    -b background color (#222222)
    -f foreground color (#3e3e3e)
    -s step (2)
    -r resolution (24)"
    exit 1
}

#args
res=24
step=4
bg="#000000"
fg="#ffffff"

# evaluate
while [ $# -gt 0 ]
do
    case "$1" in
            -b)
                bg="$2"
                shift
            ;;
            -f)
                fg="$2"
                shift
            ;;
            -s)
                step="$2"
                shift
            ;;
            -r)
                res="$2"
                shift
            ;;
            --)
                shift
                break
            ;;
            -*)
                usage
            ;;
            *)
                break
            ;;
    esac
    shift
done

# generate the image with a tiling pattern
convert -size ${res}x${res} xc:${bg} -stroke ${fg} -strokewidth 2 \
    -draw "text 10,20 '~'" /tmp/wall.png

hsetroot -cover /tmp/wall.png
