#!/bin/bash
DMENU_OPTS="-i -l 10 -x W/2 -y H/2 -w 600 -fn 'Fira Code-12'"
choice=$(printf "Config Files\nTerminal\nFile Manager\nWeb Browser\nExit" | dmenu $DMENU_OPTS -p "Menu:")

case "$choice" in
  "Config Files") 
    config=$(find ~/.config -type f | dmenu $DMENU_OPTS)
    [ "$config" ] && alacritty -e nvim "$config" ;;
  "Terminal") alacritty ;;
  "File Manager") pcmanfm ;;
  "Web Browser") firefox ;;
  "Exit") exit ;;
esac
