#!/bin/bash
# Vertikal layout - hög och smal
DMENU_ARGS="\
  -i -l 12 \
  -x W/2 -y H/2 -w 300 -h 600 \
  -fn 'Fira Code-12' \
  -nb '#2E3440' -nf '#D8DEE9' -sb '#3B4252' -sf '#E5E9F0' \
  -bw 0"

# Dynamiska menyval
CHOICES=$(printf "\
⚙️  Edit Configs\n\
📝 Recent Files\n\
📂 Quick Notes\n\
🔧 System Tools\n\
")

SELECTION=$(echo "$CHOICES" | dmenu $DMENU_ARGS -p "Menu:")

case "$SELECTION" in
  "⚙️  Edit Configs")
    CONFIG=$(printf "\
herbstluftwm\n\
zsh\n\
dunst\n\
nvim\n\
" | dmenu $DMENU_ARGS -p "Config:")
    case "$CONFIG" in
      "herbstluftwm") urxvt -e nvim ~/.config/herbstluftwm/autostart ;;
      "zsh") urxvt -e nvim ~/.zshrc ;;
      "dunst") urxvt -e nvim ~/.config/dunst/dunstrc ;;
      "nvim") urxvt -e nvim ~/.config/nvim/init.vim ;;
    esac
    ;;
  
  "📝 Recent Files")
    RECENT=$(cat ~/.config_recent | dmenu $DMENU_ARGS -l 10 -p "Recent:")
    [ -n "$RECENT" ] && urxvt -e nvim "$RECENT"
    ;;
  
  "📂 Quick Notes") urxvt -e nvim ~/notes.md ;;
  "🔧 System Tools") urxvt -e htop ;;
esac
