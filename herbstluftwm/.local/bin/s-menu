#!/bin/bash
export DISPLAY=:0
export XAUTHORITY=$HOME/.Xauthority

# Anpassad dmenu-konfig för urxvt
DMENU_CMD="/usr/bin/dmenu -i -l 10 -fn 'xft:FiraMono-12' -nb '#2E3440' -nf '#D8DEE9'"

choice=$(printf "Terminal\nWeb Browser\nConfig Files\nExit" | eval "$DMENU_CMD")

case "$choice" in
  "Terminal") /usr/bin/urxvt & ;;
  "Web Browser") /usr/bin/firefox & ;;
  "Config Files")
    config=$(find ~/.config -type f | eval "$DMENU_CMD")
    [ -n "$config" ] && /usr/bin/urxvt -e /usr/bin/nvim "$config" ;;
  "Exit") exit ;;
esac
