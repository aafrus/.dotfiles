#!/bin/bash
# iPhone-inspirerad layout
DMENU_ARGS="\
  -i -l 8 \
  -x W/2 -y H/2 -w 300 -h 500 \
  -fn 'SF Pro-12' \
  -nb '#000000' -nf '#FFFFFF' -sb '#1A1A1A' -sf '#FFFFFF' \
  -dim 0.7 -o 0.8"

# Dynamiskt innehåll
CHOICES=$(printf "\
Recently Used Configs\n\
Edit HerbstluftWM Config\n\
Edit Zsh Config\n\
Edit Dunst Config\n\
Quick Notes\n\
System Info\n\
") 

SELECTION=$(echo "$CHOICES" | dmenu $DMENU_ARGS -p "􀎬")

case "$SELECTION" in
  "Recently Used Configs")
    CONFIG=$(cat ~/.config_recent | dmenu $DMENU_ARGS)
    [ "$CONFIG" ] && urxvt -e nvim "$CONFIG" ;;
  "Edit HerbstluftWM Config") urxvt -e nvim ~/.config/herbstluftwm/autostart ;;
  "Edit Zsh Config") urxvt -e nvim ~/.zshrc ;;
  "Edit Dunst Config") urxvt -e nvim ~/.config/dunst/dunstrc ;;
  "Quick Notes") urxvt -e nvim ~/notes.md ;;
  "System Info") urxvt -e htop ;;
esac
