# Reset theme
hc attr theme.tiling.reset 1
hc attr theme.floating.reset 1

# Frame settings
hc set frame_border_active_color '#807b64'
hc set frame_border_normal_color '#131313'
hc set frame_bg_normal_color '#202020'
hc set frame_bg_active_color '#131313'
hc set frame_border_width 0
hc set always_show_frame 0
hc set frame_bg_transparent 1
hc set frame_transparent_width 0
hc set frame_gap 2

# Window theme settings
hc attr theme.active.color '#9c353e'
hc attr theme.normal.color '#594646'
hc attr theme.urgent.color '#58333e'
hc attr theme.inner_width 4
hc attr theme.inner_color '#111'
hc attr theme.border_width 0
hc attr theme.floating.border_width 5  # Overall border width
hc attr theme.floating.outer_width 5   # Outer border width
hc attr theme.floating.outer_color '#6ea2a5'  # Color of the left border
hc attr theme.active.inner_color '#111'
hc attr theme.active.outer_color '#131313'  # Match background for top, right, bottom borders
hc attr theme.background_color '#1e1b1c'
hc attr theme.padding_left 5  # Add extra padding to the left
hc attr theme.padding_right 0
hc attr theme.padding_top 0
hc attr theme.padding_bottom 0

# Gap and padding settings
hc set window_gap 30
hc set frame_padding 0
hc set smart_window_surroundings 0
hc set smart_frame_surroundings 1
hc set mouse_recenter_gap 0
